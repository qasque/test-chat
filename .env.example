# Copy to .env and fill secrets:
#   Linux/macOS: cp .env.example .env
#   Windows:     copy .env.example .env
#
# Production: set FRONTEND_URL to your public URL, then docker compose up -d

# --- Chatwoot (https://www.chatwoot.com/docs/self-hosted/configuration/environment-variables)
SECRET_KEY_BASE=replace_with_openssl_rand_hex_64
FRONTEND_URL=http://127.0.0.1:3000
FORCE_SSL=false
ENABLE_ACCOUNT_SIGNUP=false

RAILS_ENV=production
NODE_ENV=production

# Same password in REDIS_PASSWORD, REDIS_URL, and redis service
REDIS_PASSWORD=change_me_redis_strong
REDIS_URL=redis://:change_me_redis_strong@redis:6379

POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=change_me_postgres_strong
POSTGRES_DATABASE=chatwoot

MAILER_SENDER_EMAIL=Support <noreply@example.com>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
ACTIVE_STORAGE_SERVICE=local

# Optional: docker compose run --rm rails bundle exec rails db:encryption:init

# --- Telegram bridge
BRIDGE_PORT=4000
BRIDGE_SECRET=change_me_long_random_for_telegram_webhook_auth
# JWT for mobile operators (Flutter apps/mobile: email+пароль Chatwoot → POST /mobile/v1/auth/login). Мин. ~24 символа.
BRIDGE_MOBILE_JWT_SECRET=
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_PUBLIC_URL=http://127.0.0.1:3000
# TELEGRAM_BOTS_JSON={"payments_bot":{"inboxId":2,"token":"123456:AA-..."}}
TELEGRAM_BOTS_JSON=

CHATWOOT_WEBHOOK_SECRET=

# CHATWOOT_INTERNAL_URL=http://rails:3000
# BRIDGE_RUNTIME_BOTS_PATH=/data/telegram-bots-runtime.json
# BRIDGE_OUTBOUND_QUEUE_PATH=/data/telegram-outbound-queue.json
# BRIDGE_TELEGRAM_RETRY_MS=15000
# BRIDGE_TELEGRAM_MAX_ATTEMPTS=12
# BRIDGE_CORS_ORIGIN=*

# --- Demo bot: docker compose --profile demo up -d
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_KEY=demo_bot

# --- OpenClaw / ai-bot
OPENAI_API_KEY=
OPENCLAW_URL=http://openclaw:18789
OPENCLAW_GATEWAY_TOKEN=
# Enable gateway.http.endpoints.chatCompletions in OpenClaw config
# https://docs.openclaw.ai/gateway/openai-http-api
# OPENCLAW_MODEL=openclaw/default
#
# Системный промпт для ответов в чате (роль system). Пусто = встроенный дефолт в ai-bot.
# Вариант А — одна строка, переносы как \\n :
# AI_BOT_SYSTEM_PROMPT=Ты консультант.\\nКратко.\\nДля оператора: [HANDOFF]
# Вариант Б — файл внутри контейнера (смонтируй volume в Dockerfile/compose при необходимости):
# AI_BOT_SYSTEM_PROMPT_FILE=/app/config/ai-system-prompt.txt
AI_BOT_SYSTEM_PROMPT=
AI_BOT_SYSTEM_PROMPT_FILE=
CHATWOOT_BOT_TOKEN=
