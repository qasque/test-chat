# Скопируйте в .env и заполните секреты:
#   Linux/macOS: cp .env.example .env
#   Windows:     copy .env.example .env
#
# На продакшен-сервере после HTTPS и reverse proxy задайте FRONTEND_URL публичным URL, например:
#   FRONTEND_URL=https://chatwoot.example.com
# Затем: docker compose up -d

# --- Chatwoot (см. https://www.chatwoot.com/docs/self-hosted/configuration/environment-variables) ---
SECRET_KEY_BASE=replace_with_openssl_rand_hex_64
# Локально: http://127.0.0.1:3000 | Прод: https://ваш-домен (совпадает с тем, что отдаёт Nginx)
FRONTEND_URL=http://127.0.0.1:3000
FORCE_SSL=false
ENABLE_ACCOUNT_SIGNUP=false

RAILS_ENV=production
NODE_ENV=production

# Одинаковый пароль в трёх местах: redis URL, REDIS_PASSWORD, сервис redis
REDIS_PASSWORD=change_me_redis_strong
REDIS_URL=redis://:change_me_redis_strong@redis:6379

POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=change_me_postgres_strong
# Имя БД в контейнере postgres — chatwoot (как в официальном compose Chatwoot)
POSTGRES_DATABASE=chatwoot

MAILER_SENDER_EMAIL=Support <noreply@example.com>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
ACTIVE_STORAGE_SERVICE=local

# MFA/шифрование — при необходимости сгенерируйте в контейнере rails:
# docker compose run --rm rails bundle exec rails db:encryption:init

# --- Telegram bridge (этот репозиторий) ---
BRIDGE_PORT=4000
BRIDGE_SECRET=change_me_long_random_for_telegram_webhook_auth
# Токен из Super Admin или Profile Settings → Access Token (platform API)
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=1
# Публичный URL Chatwoot для ссылок в логах (опционально)
CHATWOOT_PUBLIC_URL=http://127.0.0.1:3000
# JSON: ключ бота -> inboxId Chatwoot и токен Telegram Bot API
# Пример одной строкой (экранируйте кавычки в PowerShell):
# TELEGRAM_BOTS_JSON={"payments_bot":{"inboxId":2,"token":"123456:AA-..."}}
TELEGRAM_BOTS_JSON=

# Секрет подписи webhook из Chatwoot (опционально, рекомендуется в проде)
CHATWOOT_WEBHOOK_SECRET=

# Внутренний URL Rails в Docker (уже задан в docker-compose для сервиса telegram-bridge)
# CHATWOOT_INTERNAL_URL=http://rails:3000

# Runtime-конфиг ботов из веб-портала (перекрывает ключи из TELEGRAM_BOTS_JSON)
# BRIDGE_RUNTIME_BOTS_PATH=/data/telegram-bots-runtime.json

# Очередь повторной отправки в Telegram при сбоях сети (файл на томе bridge_data)
# BRIDGE_OUTBOUND_QUEUE_PATH=/data/telegram-outbound-queue.json
# BRIDGE_TELEGRAM_RETRY_MS=15000
# BRIDGE_TELEGRAM_MAX_ATTEMPTS=12
# CORS для GET /health моста (веб-портал и Electron)
# BRIDGE_CORS_ORIGIN=*

# --- Демо Telegram-бот (docker compose --profile demo up -d) ---
# Тот же токен, что в TELEGRAM_BOTS_JSON для ключа TELEGRAM_BOT_KEY
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_KEY=demo_bot

# --- OpenClaw AI ассистент ---
OPENAI_API_KEY=
# URL OpenClaw для контейнера ai-bot (по умолчанию до сервиса openclaw в этом compose).
# Вынесенный шлюз (например NL для обхода гео OpenAI): OPENCLAW_URL=http://91.x.x.x:18789
OPENCLAW_URL=http://openclaw:18789
# Токен для доступа к API OpenClaw (задаётся при первом запуске)
OPENCLAW_GATEWAY_TOKEN=
# В ~/.openclaw/openclaw.json (том openclaw_data) включите HTTP chat, иначе мост получит 404:
# gateway.http.endpoints.chatCompletions.enabled = true
# (документация: https://docs.openclaw.ai/gateway/openai-http-api )
# Опционально: таргет агента для OpenAI-совместимого API (не id модели провайдера)
# OPENCLAW_MODEL=openclaw/default
# Токен AgentBot из Chatwoot (создаётся через Rails console)
CHATWOOT_BOT_TOKEN=
