# Copy to .env and fill secrets:
#   Linux/macOS: cp .env.example .env
#   Windows:     copy .env.example .env
#
# Production: set FRONTEND_URL to your public URL, then docker compose up -d

# --- Chatwoot (https://www.chatwoot.com/docs/self-hosted/configuration/environment-variables)
SECRET_KEY_BASE=replace_with_openssl_rand_hex_64
FRONTEND_URL=http://127.0.0.1:3000
FORCE_SSL=false
ENABLE_ACCOUNT_SIGNUP=false

RAILS_ENV=production
NODE_ENV=production

# Same password in REDIS_PASSWORD, REDIS_URL, and redis service
REDIS_PASSWORD=change_me_redis_strong
REDIS_URL=redis://:change_me_redis_strong@redis:6379

POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=change_me_postgres_strong
POSTGRES_DATABASE=chatwoot

MAILER_SENDER_EMAIL=Support <noreply@example.com>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
ACTIVE_STORAGE_SERVICE=local

# Optional: docker compose run --rm rails bundle exec rails db:encryption:init

# --- Telegram bridge
BRIDGE_PORT=4000
BRIDGE_SECRET=change_me_long_random_for_telegram_webhook_auth
# JWT для мобильных операторов (репо android-chat / ios-chat → POST /mobile/v1/auth/login). Мин. ~24 символа.
BRIDGE_MOBILE_JWT_SECRET=
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_PUBLIC_URL=http://127.0.0.1:3000
# TELEGRAM_BOTS_JSON={"payments_bot":{"inboxId":2,"token":"123456:AA-..."}}
TELEGRAM_BOTS_JSON=

CHATWOOT_WEBHOOK_SECRET=

# Уведомление при новом диалоге: в вебхуке достаточно message_created —
# мост при первом входящем сообщении (messages_count === 1) шлёт то же уведомление.
# Опционально также conversation_created (дубля не будет, если счётчик уже >1).
# URL: тот же POST …/chatwoot/webhook, что и для исходящих в Telegram.
# Опционально — Telegram группе/оператору:
# BRIDGE_NEW_CONV_NOTIFY_BOT_TOKEN=123456:AA-...
# BRIDGE_NEW_CONV_NOTIFY_CHAT_ID=-100xxxxxxxxxx
# Ссылка в тексте уведомления (публичный URL панели Chatwoot):
# BRIDGE_NOTIFICATION_CHATWOOT_BASE_URL=https://msk.kosmosapp.ru
# Или произвольный POST (n8n, свой сервис) с полным JSON вебхука:
# BRIDGE_NEW_CONV_HOOK_URL=https://example.com/hooks/chatwoot-new-conv

# CHATWOOT_INTERNAL_URL=http://rails:3000
# BRIDGE_RUNTIME_BOTS_PATH=/data/telegram-bots-runtime.json
# BRIDGE_OUTBOUND_QUEUE_PATH=/data/telegram-outbound-queue.json
# BRIDGE_TELEGRAM_RETRY_MS=15000
# BRIDGE_TELEGRAM_MAX_ATTEMPTS=12
# BRIDGE_CORS_ORIGIN=*

# --- Demo bot: docker compose --profile demo up -d
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_KEY=demo_bot

# --- OpenClaw / ai-bot
# OpenAI: openclaw + прямой Whisper STT в ai-bot (если Groq с сервера недоступен).
OPENAI_API_KEY=
# Groq: прямой STT в ai-bot. С серверов в РФ часто 403 Forbidden (региональное ограничение Groq).
GROQ_API_KEY=
OPENCLAW_URL=http://openclaw:18789
# Только транскрипция голоса через OpenClaw на другом хосте (например NL — тогда Groq не режет по региону).
# Тот же токен, что GATEWAY_TOKEN на том OpenClaw, если не задать OPENCLAW_STT_TOKEN.
# OPENCLAW_STT_URL=http://IP_ИЛИ_ДОМЕН_NL:18789
# OPENCLAW_STT_TOKEN=
# Если задан OPENCLAW_STT_URL, прямой вызов api.groq.com из ai-bot отключён (иначе 403 с РФ). Обход: GROQ_STT_DIRECT=1
OPENCLAW_GATEWAY_TOKEN=
#
# Groq STT через relay на NL (профиль nl-stt): на MSK задайте базовый URL без пути, на NL поднимите stt-groq-relay.
# STT_GROQ_RELAY_URL=http://IP_NL:8787
# STT_RELAY_TOKEN=общий_секрет_с_контейнером_relay
# Enable gateway.http.endpoints.chatCompletions in OpenClaw config
# https://docs.openclaw.ai/gateway/openai-http-api
# OPENCLAW_MODEL=openclaw/default
#
# Голос → текст через OpenClaw /v1/audio/transcriptions (нужны OPENAI_API_KEY в контейнере openclaw
# и включённый audio/STT в конфиге OpenClaw, см. docs.openclaw.ai nodes/audio).
# Agent target в multipart form и backend в заголовке (как у /v1/embeddings):
# OPENCLAW_STT_AGENT_MODEL=openclaw/default
# OPENCLAW_STT_MODEL=groq/whisper-large-v3-turbo
# OPENCLAW_STT_LANGUAGE=ru
#
# Прямой Groq STT в ai-bot (приоритетнее OpenClaw): см. GROQ_API_KEY выше.
# GROQ_STT_MODEL=whisper-large-v3-turbo
#
# Только STT (если не хотите светить общий OPENAI_API_KEY в ai-bot): OPENAI_API_KEY_STT=sk-...
# OPENAI_STT_MODEL=whisper-1
#
# Системный промпт для ответов в чате (роль system). Пусто = встроенный дефолт в ai-bot.
# Вариант А — одна строка, переносы как \\n :
# AI_BOT_SYSTEM_PROMPT=Ты консультант.\\nКратко.\\nДля оператора: [HANDOFF]
# Промпт по умолчанию — файл ./config/ai-system-prompt.txt (volume в docker-compose у ai-bot).
# Не задавайте AI_BOT_SYSTEM_PROMPT_FILE= с пустым значением в .env — иначе в контейнер уйдёт пустая строка.
# Переопределить одной строкой (без файла): задайте AI_BOT_SYSTEM_PROMPT.
AI_BOT_SYSTEM_PROMPT=
CHATWOOT_BOT_TOKEN=
